--- CONSULTA PARA SABER A QTD DE MATERIA PRIMA E SEU NOME 
SELECT c.[Materia Prima], m.[Nome MP] ,COUNT(*) as qtd_mp
FROM fCompras$ as c
JOIN dMateriaPrima$ as m
ON c.[Materia Prima] = m.[Codigo MP]
GROUP BY c.[Materia Prima], m.[Nome MP]
ORDER BY [Materia Prima] ASC

---- CRIANDO UMA TABELA CALENDARIO 
SELECT 
    MIN([Data Pedido]) AS DataInicial,
    MAX([Data Pedido]) AS DataFinal
FROM fCompras$;

CREATE TABLE Calendario (
    Data DATE PRIMARY KEY,
    Ano INT,
    Mes INT,
    NomeMes VARCHAR(20),
    AnoMes VARCHAR(7),
    Trimestre INT,
    DiaSemana INT,
    NomeDiaSemana VARCHAR(25)
);

SET LANGUAGE Portuguese;

DECLARE @DataAtual DATE = '2019-01-20';
DECLARE @DataFinal DATE = '2022-01-01';

WHILE @DataAtual <= @DataFinal
BEGIN
    INSERT INTO Calendario (Data, Ano, Mes, NomeMes, AnoMes, Trimestre, DiaSemana, NomeDiaSemana)
    VALUES (
        @DataAtual,
        YEAR(@DataAtual),
        MONTH(@DataAtual),
        DATENAME(MONTH, @DataAtual),
        FORMAT(@DataAtual, 'yyyy-MM'),
        DATEPART(QUARTER, @DataAtual),
        DATEPART(WEEKDAY, @DataAtual),
        DATENAME(WEEKDAY, @DataAtual)
    );

    SET @DataAtual = DATEADD(DAY, 1, @DataAtual);
END


