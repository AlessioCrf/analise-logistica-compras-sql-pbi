---TOTAL DE GASTO POR COMPRADOR 
SELECT ca.AnoMes,
	   com.[Nome Comprador],
	   m.[Nome MP],
	   ROUND(SUM(c.Quantidade * m.[Custo UnitĂˇrio] * ( 1 - ISNULL(c.[Desconto (%)],0))),2) as totalgasto
FROM fCompras$ as c
JOIN Calendario as ca
ON c.[Data Pedido] = ca.Data
JOIN dComprador$ as com
ON c.Comprador = com.[Codigo Comprador]
JOIN dMateriaPrima$ as m 
ON c.[Materia Prima] = m.[Codigo MP]
GROUP BY ca.AnoMes,
	   com.[Nome Comprador],
	   m.[Nome MP]
ORDER BY AnoMes ASC

