---COMPRADOR QUE MAIS FEZ PEDIDOS 
SELECT  ca.Ano,
        com.[Nome Comprador],
		m.[Nome MP],
		SUM(Quantidade) as totalpedido
FROM fCompras$ as c
Join Calendario as ca
ON c.[Data Pedido] = ca.Data
Join dComprador$ as com
ON c.Comprador = com.[Codigo Comprador]
Join dMateriaPrima$ as m
ON c.[Materia Prima] = m.[Codigo MP]
GROUP BY ca.Ano, com.[Nome Comprador], m.[Nome MP]
ORDER BY totalpedido DESC

